<?xml version="1.0" encoding="UTF-8" ?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package
        Name="rfshare"
        Version="0.8.0"
        Manufacturer="Imrany"
        Language="1033"
        UpgradeCode="B1A2C3D4-E5F6-7890-ABCD-EF1234567890"
    >

    <SummaryInformation Description="Fast, encrypted file transfers" />

    <MajorUpgrade
            DowngradeErrorMessage="A newer version of rfshare is already installed."
        />

    <Property Id="MSIINSTALLPERUSER" Value="1" />

    <Property Id="INSTALLFOLDER">
      <RegistrySearch
                Id="InstallFolderSearch"
                Root="HKCU"
                Key="Software\rfshare"
                Name="InstallFolder"
                Type="raw"
            />
    </Property>

    <SetProperty
            Id="INSTALLFOLDER"
            Value="[LocalAppDataFolder]rfshare"
            After="AppSearch"
            Sequence="both"
            Condition="NOT INSTALLFOLDER"
        />

    <SetProperty
            Id="AppMenuFolder"
            Value="[ProgramMenuFolder]rfshare"
            After="AppSearch"
            Sequence="both"
            Condition="NOT AppMenuFolder"
        />

    <StandardDirectory Id="LocalAppDataFolder" />
    <StandardDirectory Id="ProgramMenuFolder" />

    <ComponentGroup Id="ProductComponents" Directory="LocalAppDataFolder">
      <Component
                Id="MainExecutable"
                Guid="A1B2C3D4-E5F6-7890-ABCD-111111111111"
            >
        <File
                    Id="rfshareEXE"
                    Source="rfshare.exe"
                    Name="rfshare.exe"
                    KeyPath="yes"
                />
        <Environment
                    Id="UserPATH"
                    Name="PATH"
                    Value="[INSTALLFOLDER]"
                    Permanent="no"
                    Part="last"
                    Action="set"
                    System="no"
                />
        <RegistryValue
                    Root="HKCU"
                    Key="Software\rfshare"
                    Name="InstallFolder"
                    Type="string"
                    Value="[INSTALLFOLDER]"
                />
      </Component>

      <Component Id="AppIconComp" Guid="A1B2C3D4-E5F6-7890-ABCD-222222222222">
        <File
                    Id="rfshareICO"
                    Source="rfshare.ico"
                    Name="rfshare.ico"
                    KeyPath="yes"
                />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="ShortcutComponents" Directory="ProgramMenuFolder">
      <Component
                Id="StartMenuShortcut"
                Guid="A1B2C3D4-E5F6-7890-ABCD-333333333333"
            >
        <Shortcut
                    Id="AppShortcut"
                    Name="rfshare"
                    Description="Fast, encrypted LAN file transfers"
                    Target="[INSTALLFOLDER]rfshare.exe"
                    WorkingDirectory="LocalAppDataFolder"
                    Icon="AppIcon"
                />
        <RemoveFolder
                    Id="CleanupStartMenu"
                    Directory="ProgramMenuFolder"
                    On="uninstall"
                />
        <RegistryValue
                    Root="HKCU"
                    Key="Software\rfshare"
                    Name="ShortcutInstalled"
                    Type="integer"
                    Value="1"
                    KeyPath="yes"
                />
      </Component>
    </ComponentGroup>

    <Icon Id="AppIcon" SourceFile="rfshare.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property
            Id="ARPHELPLINK"
            Value="https://github.com/imrany/rfshare/issues"
        />
    <Property Id="ARPURLINFOABOUT" Value="https://rfshare.imrany.dev" />
    <Property Id="ARPNOREPAIR" Value="1" />

    <Feature Id="ProductFeature" Title="rfshare" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="ShortcutComponents" />
    </Feature>

  </Package>
</Wix>
